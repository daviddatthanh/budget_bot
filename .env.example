# Plaid credentials for Wally.
#
# EASIEST: you do NOT need to edit this file. Open the app, go to
# Settings -> Bank Connections, and paste your keys into the "Connect Plaid"
# form. They're saved to data/plaid_config.json and applied instantly.
#
# This .env path is an optional fallback (e.g. for headless setups). Copy this
# file to ".env" (same folder) and paste in your keys from
# https://dashboard.plaid.com/developers/keys. Note: keys saved in the in-app
# form take precedence over anything set here.

PLAID_CLIENT_ID=
PLAID_SECRET=

# "production" (real banks) or "sandbox" (test banks: user_good / pass_good)
PLAID_ENV=production

# Optional. Required only for OAuth banks (Chase, Wells Fargo, Capital One, etc.).
# Must be registered under Plaid dashboard -> Team Settings -> API -> Allowed redirect URIs.
# For this local app use your frontend origin, e.g. http://localhost:5173
PLAID_REDIRECT_URI=
